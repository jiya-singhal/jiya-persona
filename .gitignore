# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Environments
.env
.env.local
.venv/
venv/
backend/.env

# Node
node_modules/
.next/
.vercel/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Eval results — commit the canonical latest.json + the 1-page PDF.
# Other JSON files in evals/results/ are intermediates and ignored.
evals/results/*.json
!evals/results/.gitkeep
!evals/results/latest.json

# Local-only runtime data (the latency log is regenerated per session)
backend/data/latency.sqlite

# Logs (but NOT chroma.sqlite3 — that ships with the image)
*.log

# Local Playwright/screenshot output (Phase 4 artifacts)
screenshots/
.playwright-mcp/

# IMPORTANT: backend/data/chroma_db/ and backend/data/repo_cards/ are NOT
# ignored — they ship with the image so Render boots with the RAG corpus
# baked in. Regenerating at boot would burn Gemini API calls and add minutes
# to cold-start.
